# Copy this file to .env in the repository root and fill in your keys.
# Never commit .env to git.

# Required for the provider you plan to use (set at least one).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider ClaimVerifier should use by default: openai | anthropic
DEFAULT_PROVIDER=anthropic

# Optional model overrides
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional request tuning
REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=2
